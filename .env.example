# Required for the CLI (and for the Action via the anthropic-api-key input)
ANTHROPIC_API_KEY=sk-ant-...

# Required for the CLI: a GitHub token with repo read access (and PR write access for --post)
GITHUB_TOKEN=ghp_...

# Optional overrides (CLI flags take precedence)
# RECENSIO_MODEL=claude-opus-4-8
# RECENSIO_EFFORT=xhigh          # low | medium | high | xhigh | max
# RECENSIO_MIN_LOC=500
# RECENSIO_MAX_TURNS=40
